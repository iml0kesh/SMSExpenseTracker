<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimary">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_close"
            app:navigationIconTint="?attr/colorOnPrimary"
            app:title="Monthly Budgets"
            app:titleTextColor="?attr/colorOnPrimary"
            app:elevation="0dp"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Info banner -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="?attr/colorSecondaryContainer"
        app:cardElevation="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:text="Set a monthly limit per category. Progress turns orange at 75% and red when exceeded. Long-press any transaction to re-tag it."
            android:textColor="?attr/colorOnSecondaryContainer"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"/>

    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/budgetRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <!-- Save button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:background="?attr/colorSurface"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBudgets"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Budgets"
            android:textSize="15sp"
            android:fontFamily="@font/nunito_bold"
            app:backgroundTint="?attr/colorPrimary"
            app:cornerRadius="10dp"
            android:textColor="?attr/colorOnPrimary"/>

    </LinearLayout>

</LinearLayout>
