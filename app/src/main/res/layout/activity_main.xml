<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground">

    <!-- ── SCROLLABLE CONTENT ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ╔══════════════════════════════════════╗ -->
            <!-- ║   SPENDING OVERVIEW CARD             ║ -->
            <!-- ╚══════════════════════════════════════╝ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/spending_card_bg"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="35dp"
                android:paddingBottom="32dp">

                <!-- App title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spending Overview"
                        android:textColor="#80FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/nunito"/>

                </LinearLayout>

                <!-- Sync progress bar inside header -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/mainProgress"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginBottom="16dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:trackCornerRadius="1dp"
                    app:indicatorColor="#FFFFFF"
                    app:trackColor="#33FFFFFF"/>

                <!-- 2x2 stats grid -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_columnWeight="1" android:orientation="vertical"
                        android:paddingEnd="8dp" android:paddingBottom="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TODAY" android:textColor="#66FFFFFF" android:textSize="11sp"
                            android:letterSpacing="0.14" android:fontFamily="@font/nunito"/>
                        <TextView android:id="@+id/tvToday" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0"
                            android:textColor="#FFFFFF" android:textSize="30sp"
                            android:fontFamily="@font/nunito_bold" android:layout_marginTop="2dp"
                            tools:text="₹0"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_columnWeight="1" android:orientation="vertical"
                        android:paddingStart="8dp" android:paddingBottom="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="THIS WEEK" android:textColor="#66FFFFFF" android:textSize="11sp"
                            android:letterSpacing="0.14" android:fontFamily="@font/nunito"/>
                        <TextView android:id="@+id/tvWeek" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0"
                            android:textColor="#FFFFFF" android:textSize="30sp"
                            android:fontFamily="@font/nunito_bold" android:layout_marginTop="2dp"
                            tools:text="₹52.8K"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_columnWeight="1" android:orientation="vertical"
                        android:paddingEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="THIS MONTH" android:textColor="#66FFFFFF" android:textSize="11sp"
                            android:letterSpacing="0.14" android:fontFamily="@font/nunito"/>
                        <TextView android:id="@+id/tvMonth" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0"
                            android:textColor="#FFFFFF" android:textSize="30sp"
                            android:fontFamily="@font/nunito_bold" android:layout_marginTop="2dp"
                            tools:text="₹69.6K"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_columnWeight="1" android:orientation="vertical"
                        android:paddingStart="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="THIS YEAR" android:textColor="#66FFFFFF" android:textSize="11sp"
                            android:letterSpacing="0.14" android:fontFamily="@font/nunito"/>
                        <TextView android:id="@+id/tvYear" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0"
                            android:textColor="#FFFFFF" android:textSize="30sp"
                            android:fontFamily="@font/nunito_bold" android:layout_marginTop="2dp"
                            tools:text="₹97.9K"/>
                    </LinearLayout>

                </GridLayout>
            </LinearLayout>

            <!-- ╔══════════════════════════════════════╗ -->
            <!-- ║   CONTENT SECTION (dark background)  ║ -->
            <!-- ╚══════════════════════════════════════╝ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <!-- Bank filter chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="4dp">
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/bankChipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"/>
                </HorizontalScrollView>

                <!-- This Month insights -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="10dp"
                    android:text="This Month"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:fontFamily="@font/nunito_bold"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <LinearLayout
                        android:id="@+id/insightsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">
                        <TextView
                            android:id="@+id/tvNoInsights"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No spending data yet"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                            android:fontFamily="@font/nunito"
                            android:padding="8dp"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Transactions header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:id="@+id/tvLabelTransactions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transactions"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:fontFamily="@font/nunito_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/tvLabelTransactions"
                        android:layout_marginStart="6dp"
                        android:layout_alignBaseline="@id/tvLabelTransactions"
                        android:text="· tap to view"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp"
                        android:fontFamily="@font/nunito"/>

                </RelativeLayout>

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/emptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="48dp"
                    android:paddingBottom="32dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📭"
                        android:textSize="44sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="No transactions yet"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:fontFamily="@font/nunito_bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Tap ⚙ below → Refresh"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        android:fontFamily="@font/nunito"/>
                </LinearLayout>

                <!-- Transaction list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"/>

                <!-- Load more / end -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoadMore"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Load More"
                        android:textColor="?attr/colorPrimary"
                        android:fontFamily="@font/nunito"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvNoMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="All caught up ✓"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:fontFamily="@font/nunito"
                        android:visibility="gone"/>
                </FrameLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ╔══════════════════════════════════════╗ -->
    <!-- ║   BOTTOM ACTION BAR                  ║ -->
    <!-- ╚══════════════════════════════════════╝ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@drawable/bottom_bar_bg"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <!-- App name / left -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SMS Expense Tracker"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:fontFamily="@font/nunito"/>

        <!-- Export CSV button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabExport"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Export"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            android:fontFamily="@font/nunito"
            app:icon="@android:drawable/ic_menu_save"
            app:iconTint="?attr/colorPrimary"
            app:iconSize="18dp"/>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="?attr/colorOutline"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Settings button — opens bottom sheet with all menu items -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:icon="@drawable/ic_settings"
            app:iconTint="?attr/colorOnSurfaceVariant"
            app:iconSize="22dp"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
