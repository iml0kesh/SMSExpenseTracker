<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        SET — Midnight Blue  |  Nunito font
        Background   #0D1117
        Surface      #111827
        SurfaceVar   #1C2333
        Elevated     #243044
        Primary      #0EA5E9
        Credit       #10B981
        Debit        #F87171
    -->
    <style name="Theme.SMSExpenseTracker" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">#0A1218</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#0C2461</item>
        <item name="colorOnPrimaryContainer">#BAE6FD</item>

        <item name="colorSecondary">#10B981</item>
        <item name="colorOnSecondary">#022C22</item>
        <item name="colorSecondaryContainer">#064E3B</item>
        <item name="colorOnSecondaryContainer">#A7F3D0</item>

        <item name="colorTertiary">#38BDF8</item>
        <item name="colorOnTertiary">#082F49</item>
        <item name="colorTertiaryContainer">#0C4A6E</item>
        <item name="colorOnTertiaryContainer">#BAE6FD</item>

        <item name="colorError">#F87171</item>
        <item name="colorOnError">#3D0000</item>
        <item name="colorErrorContainer">#5C1A1A</item>
        <item name="colorOnErrorContainer">#FFCDD2</item>

        <item name="android:colorBackground">#0D1117</item>
        <item name="colorSurface">#111827</item>
        <item name="colorSurfaceVariant">#1C2333</item>
        <item name="colorOnSurface">#F0F6FF</item>
        <item name="colorOnSurfaceVariant">#8B9CB6</item>
        <item name="colorOutline">#2A3A52</item>
        <item name="colorOutlineVariant">#1A2538</item>

        <item name="android:statusBarColor">#0D1117</item>
        <item name="android:navigationBarColor">#0D1117</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowAnimationStyle">@null</item>

        <!-- Nunito as app-wide font -->
        <item name="android:fontFamily">@font/nunito</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SET.Dialog</item>
        <item name="bottomSheetDialogTheme">@style/BottomSheetDialogTheme</item>

    </style>

    <style name="ThemeOverlay.SET.Dialog"
           parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">#243044</item>
        <item name="colorOnSurface">#F0F6FF</item>
        <item name="colorPrimary">#0EA5E9</item>
        <item name="colorOnSurfaceVariant">#8B9CB6</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>

    <style name="BottomSheetDialogTheme"
           parent="Theme.Material3.DayNight.BottomSheetDialog">
        <item name="colorSurface">#243044</item>
        <item name="colorOnSurface">#F0F6FF</item>
        <item name="colorPrimary">#0EA5E9</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>

</resources>
